# Esempio di env per `docker compose up`.
#
# IN PRODUZIONE NON USARE QUESTO FILE.
# Usare invece:    doppler run -- docker compose up -d
#
# Questo file serve solo a:
#   - documentare le variabili attese
#   - testare il setup in locale (con valori dummy che fanno fallire
#     volontariamente entrypoint.sh — è il comportamento corretto)

# Cap di spesa giornaliero (in USD)
ANTHROPIC_DAILY_USD_CAP=10
OPENCLAW_VERSION=latest

# Tutto quello che segue deve venire da Doppler / vault in produzione:
ANTHROPIC_API_KEY=sk-ant-CHANGEME
AGENT_RO_DATABASE_URL=postgresql://agent_ro:CHANGEME@host:5432/db
GITHUB_AGENT_TOKEN=github_pat_CHANGEME
TELEGRAM_BOT_TOKEN=CHANGEME
TELEGRAM_CHAT_ID=CHANGEME
WEBHOOK_HMAC_SECRET=CHANGEME

# Opzionale: virgola-separato. Vuoto = nessuna IP allowlist (solo HMAC)
ALLOWED_SOURCE_IPS=
